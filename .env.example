# FreshRSS API
FRESHRSS_API_URL=https://your-freshrss.example.com/api/greader.php
FRESHRSS_USERNAME=your_username
FRESHRSS_PASSWORD=your_api_password

# AI Model (provider:model format)
AI_MODEL=zhipu:glm-4.7-flash

# API Keys (set the one matching your AI_MODEL provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Lightpanda (optional, for full-text extraction L2)
LIGHTPANDA_URL=ws://127.0.0.1:9222

# Fetch config
MAX_TOTAL=100
MIN_PER_FEED=3
MAX_PER_FEED=10
